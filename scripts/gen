#!/usr/bin/env python3
"""Regenerate plugin index, format docs, and related generated files."""

from __future__ import annotations

from pathlib import Path
import runpy


def main() -> int:
	script_dir = Path(__file__).resolve().parent
	doc_p = (script_dir / ".." / "doc" / "p").resolve()
	if doc_p.is_dir():
		for md in doc_p.glob("*.md"):
			md.unlink()

	gen_d = script_dir / "gen.d"
	for name in (
		"plugin-index.py",
		"plugin-doc.py",
		"config-doc.py",
		"entry-filters-doc.py",
		"requirements.py",
	):
		print(name)
		runpy.run_path(str(gen_d / name))
	return 0


if __name__ == "__main__":
	raise SystemExit(main())
